---
import { mixStaticPaths } from "../../../astro/mixStaticPaths";
import Flex from "../../../components/Flex.astro";
import Heading from "../../../components/Heading.astro";
import { itemSlugs } from "../../../game/slugs";
import "../../../game/tags";
import { unqualify } from "../../../game/unqualify";
import { vfs } from "../../../game/vfs";
import { getStrings } from "../../../i18n/getStrings";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import type { ItemSectionShouldRenderContext } from "../../../types/itemSectionConfig";
import { itemSections } from "../../../ui/itemSections.astro";
import { getStaticPaths as _getStaticPaths } from "../index.astro";

export const getStaticPaths = mixStaticPaths(_getStaticPaths, () =>
  itemSlugs.map(({ slug, id }) => ({ params: { slug }, props: { id } })),
);

const { locale, id } = Astro.props;
const { slug } = Astro.params;

const unqualified = unqualify(id);

const components = await vfs.components(unqualified);
const gameStrings = await vfs.strings(locale);
const itemNameComponent = components.get("minecraft:item_name");

const strings = await getStrings(locale);
---

<BaseLayout {locale}>
  <Heading minecraft>
    {gameStrings.get(itemNameComponent.translate)}
  </Heading>

  {
    itemSections.map(async (section) => {
      const components = await vfs.components(unqualified);
      const context: ItemSectionShouldRenderContext = { id, components };

      if (!(await section.shouldRender(context))) return null;

      return (
        <Flex column gap="4">
          <Heading size="2">
            {
              strings.items.sections[
                section.name as keyof typeof strings.items.sections
              ].title
            }
          </Heading>

          <section.renderer {slug} {locale} {id} {unqualified} {components} />
        </Flex>
      );
    })
  }
</BaseLayout>
