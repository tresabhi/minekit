---
import type { GetStaticPaths } from "astro";
import Flex from "../../components/Flex.astro";
import Link from "../../components/Link.astro";
import { blockSlugs } from "../../game/blocks";
import { unqualify } from "../../game/unqualify";
import { gameStrings } from "../../i18n/gameStrings";
import locales from "../../i18n/locales.json";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const getStaticPaths = (() => {
  return Object.keys(locales.locales).map((id) => ({
    params: { locale: id === locales.default ? undefined : id },
    props: { locale: id },
  }));
}) satisfies GetStaticPaths;

const { locale } = Astro.props;

const blockString = await gameStrings(locale, "block.minecraft");
---

<style>
  .title {
    display: flex;
    justify-content: center;

    padding: var(--u4) 0;

    .image {
      width: calc(40 * var(--u2));
    }
  }
</style>

<BaseLayout {locale}>
  <Flex wrap gap="2">
    {
      blockSlugs.map(({ id, slug }) => {
        return (
          <Link href={`/blocks/${slug}`}>{blockString(unqualify(id))}</Link>
        );
      })
    }
  </Flex>
</BaseLayout>
