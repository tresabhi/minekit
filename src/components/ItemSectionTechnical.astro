---
import { TagAccessor } from "../game/tagAccessor";
import { getStrings } from "../i18n/getStrings";
import type { ItemSectionProps } from "../types/itemSectionProps";
import Badge from "./Badge.astro";
import Code from "./Code.astro";
import Flex from "./Flex.astro";
import Text from "./Text.astro";

type Props = ItemSectionProps;

const { locale, id, components } = Astro.props;

const strings = await getStrings(locale);
const itemTags = new TagAccessor("item");

const formattedTags = itemTags
  .applied(id)
  .sort((a, b) => a.localeCompare(b, locale));
const formattedComponents = components
  .keys()
  .sort((a, b) => a.localeCompare(b, locale));
---

{
  formattedTags.length > 0 && (
    <Flex column gap="1">
      <Text>{strings.items.sections.technical.tags}</Text>

      <Flex wrap gap="1">
        {formattedTags.map((tag) => (
          <Badge>
            <Code>{tag}</Code>
          </Badge>
        ))}
      </Flex>
    </Flex>
  )
}

<Flex column gap="1">
  <Text>
    {strings.items.sections.technical.components}
  </Text>

  <Flex wrap gap="1">
    {
      formattedComponents.map((tag) => (
        <Badge>
          <Code>{tag}</Code>
        </Badge>
      ))
    }
  </Flex>
</Flex>
