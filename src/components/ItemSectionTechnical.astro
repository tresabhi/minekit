---
import { TagAccessor } from "../game/tagAccessor";
import { getStrings } from "../i18n/getStrings";
import type { ItemSectionProps } from "../types/itemSectionProps";
import Badge from "./Badge.astro";
import Code from "./Code.astro";
import FactSheetCell from "./FactSheetCell.astro";
import FactSheetRoot from "./FactSheetRoot.astro";
import FactSheetRow from "./FactSheetRow.astro";
import Flex from "./Flex.astro";

type Props = ItemSectionProps;

const { locale, id, components, slug } = Astro.props;

const strings = await getStrings(locale);
const itemTags = new TagAccessor("item");

const formattedTags = itemTags
  .applied(id)
  .sort((a, b) => a.localeCompare(b, locale));
const formattedComponents = components
  .keys()
  .sort((a, b) => a.localeCompare(b, locale));
---

<FactSheetRoot>
  <FactSheetRow>
    <FactSheetCell header>
      {strings.items.sections.technical.id}
    </FactSheetCell>

    <FactSheetCell>
      <Badge>
        <Code>{id}</Code>
      </Badge>
    </FactSheetCell>
  </FactSheetRow>

  <FactSheetRow>
    <FactSheetCell header>
      {strings.items.sections.technical.slug}
    </FactSheetCell>

    <FactSheetCell>
      <Badge>
        <Code>{slug}</Code>
      </Badge>
    </FactSheetCell>
  </FactSheetRow>

  {
    formattedTags.length > 0 && (
      <FactSheetRow>
        <FactSheetCell header>
          {strings.items.sections.technical.tags}
        </FactSheetCell>

        <FactSheetCell>
          <Flex wrap gap="1">
            {formattedTags.map((tag) => (
              <Badge>
                <Code>{tag}</Code>
              </Badge>
            ))}
          </Flex>
        </FactSheetCell>
      </FactSheetRow>
    )
  }

  <FactSheetRow>
    <FactSheetCell header>
      {strings.items.sections.technical.components}
    </FactSheetCell>

    <FactSheetCell>
      <Flex wrap gap="1">
        {
          formattedComponents.map((tag) => (
            <Badge>
              <Code>{tag}</Code>
            </Badge>
          ))
        }
      </Flex>
    </FactSheetCell>
  </FactSheetRow>
</FactSheetRoot>
