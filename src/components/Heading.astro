---
interface Props {
  size?: `${1 | 2}`;
  minecraft?: boolean;
}

const { size = "1", minecraft } = Astro.props;
---

<style>
  .heading {
    font-weight: var(--weight-bold);
    font-family: var(--font-regular);

    &[data-size="1"] {
      font-size: calc(3 * var(--u-rem));
    }

    &[data-size="2"] {
      font-size: calc(2 * var(--u-rem));
    }

    &[data-minecraft="true"] {
      font-family: var(--font-minecraft);
    }
  }
</style>

<span class="heading" data-size={size} data-minecraft={minecraft}>
  <slot />
</span>
