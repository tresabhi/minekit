---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"img"> & {
  resolution?: string;
};

const { resolution, class: className, ...props } = Astro.props;
---

<style>
  .texture {
    image-rendering: pixelated;
  }
</style>

<img
  class:list={["texture", className]}
  style={resolution
    ? `width: calc(${resolution} * var(--u-vanilla-scale));`
    : undefined}
  {...props}
/>
