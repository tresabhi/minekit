---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"th" | "td"> {
  header?: boolean;
}

const { header, class: className, ...props } = Astro.props;
---

<style>
  .cell {
    padding: var(--u2);
    vertical-align: top;

    th& {
      text-align: left;
    }
  }
</style>

{
  header && (
    <th class:list={["cell", className]} {...props}>
      <slot />
    </th>
  )
}

{
  !header && (
    <td class:list={["cell", className]} {...props}>
      <slot />
    </td>
  )
}
